# Dependencies
node_modules/
package-lock.json
yarn.lock

# Environment variables
.env
.env.local
.env.*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Temporary files
*.swp
*.swo
*~

# Config files
config.js
config.json

# PDF files (since this is a PDF processing app, we probably don't want to commit the PDFs)
*.pdf

# Keep docs-to-import directory but ignore its contents
docs-to-import/*
!docs-to-import/.gitkeep

